// Sticky CTA bar — appears after hero scrolls out of view.
const stickyCtaStyles = `
.fpc-sticky-cta {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  z-index: 55;
  background: var(--ink);
  color: #fff;
  border-top: 2px solid var(--accent);
  padding: 12px var(--pad-x);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  transform: translateY(120%);
  transition: transform 360ms cubic-bezier(.2,.7,.2,1);
  box-shadow: 0 -8px 24px rgba(0,0,0,0.3);
}
.fpc-sticky-cta.show { transform: translateY(0); }
.fpc-sticky-cta .left {
  display: flex; align-items: center; gap: 16px;
  font-family: var(--body);
  font-weight: 700;
  font-size: 14px;
  letter-spacing: 0.02em;
}
.fpc-sticky-cta .left .price {
  font-family: var(--display);
  font-style: italic;
  font-weight: 800;
  font-size: 28px;
  line-height: 1;
  letter-spacing: 0;
}
.fpc-sticky-cta .left .price .accent { color: var(--accent-2); }
.fpc-sticky-cta .left .sub {
  font-size: 12px;
  font-weight: 600;
  color: rgba(255,255,255,0.7);
  letter-spacing: 0.06em;
  text-transform: uppercase;
}
.fpc-sticky-cta .right {
  display: flex; gap: 12px; align-items: center;
}

@media (max-width: 640px) {
  .fpc-sticky-cta .left .sub { display: none; }
  .fpc-sticky-cta .left .price { font-size: 22px; }
  .fpc-sticky-cta .right .btn--call { display: none; }
}
`;

function StickyCTA() {
  const [show, setShow] = React.useState(false);
  React.useEffect(() => {
    const onScroll = () => setShow(window.scrollY > window.innerHeight * 0.9);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
    return () => window.removeEventListener('scroll', onScroll);
  }, []);

  return (
    <React.Fragment>
      <style>{stickyCtaStyles}</style>
      <div className={`fpc-sticky-cta ${show ? 'show' : ''}`}>
        <div className="left">
          <div>
            <div className="sub">Starting at only</div>
            <div className="price"><span className="accent">$54</span>/mo</div>
          </div>
        </div>
        <div className="right">
          <a className="btn btn--ghost btn--sm btn--call" href="tel:4794040800" style={{ borderColor: '#fff', color: '#fff', boxShadow: 'none' }}>
            <Ic.Phone /> (479) 404-0800
          </a>
          <a className="btn btn--on-dark btn--sm" href="#quote">
            Get Free Quote <Ic.Arrow width="14" height="14" />
          </a>
        </div>
      </div>
    </React.Fragment>);

}

window.StickyCTA = StickyCTA;